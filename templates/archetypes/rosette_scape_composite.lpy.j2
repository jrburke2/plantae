ROSETTE_LEAF_LEN_MIN_M = {{ "%.6f" % m.rosette.leaf_length_min }}
ROSETTE_LEAF_LEN_MAX_M = {{ "%.6f" % m.rosette.leaf_length_max }}
ROSETTE_PHYLLOTAXY_DEG = {{ species.parameters.rosette.divergence_angle_deg }}

SCAPE_COUNT_MIN = {{ species.parameters.scape.count_range[0] }}
