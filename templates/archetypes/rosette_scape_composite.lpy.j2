INFLORESCENCE_DIAMETER_MIN_M = {{ "%.6f" % m.inflorescence.diameter_min }}
INFLORESCENCE_DIAMETER_MAX_M = {{ "%.6f" % m.inflorescence.diameter_max }}
RAY_COUNT_MIN = {{ species.parameters.inflorescence.ray_count_range[0] }}
RAY_COUNT_MAX = {{ species.parameters.inflorescence.ray_count_range[1] }}

