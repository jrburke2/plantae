LEAF_GROWTH_DAYS = 14.0
SEGMENT_GROWTH_DAYS = 1.0
RAY_GROWTH_DAYS = 7.0
DISK_GROWTH_DAYS = 5.0
INFLO_BUD_GROWTH_DAYS = 5.0

# === Scape segmentation: fixed segment count; per-segment length scales with height ===
SCAPE_SEGMENT_COUNT = 30

# === Per-specimen stochastic draws (same seed -> bit-identical specimen) ===
ROSETTE_LEAVES = random.randint(ROSETTE_LEAF_COUNT_MIN, ROSETTE_LEAF_COUNT_MAX)
SCAPE_COUNT = random.randint(SCAPE_COUNT_MIN, SCAPE_COUNT_MAX)
SCAPE_HEIGHT_M = random.uniform(SCAPE_HEIGHT_MIN_M, SCAPE_HEIGHT_MAX_M)
SCAPE_SEGMENT_LEN_M = SCAPE_HEIGHT_M / SCAPE_SEGMENT_COUNT
ROSETTE_LEAF_MAX_LEN_M = random.uniform(ROSETTE_LEAF_LEN_MIN_M, ROSETTE_LEAF_LEN_MAX_M)
RAY_COUNT = random.randint(RAY_COUNT_MIN, RAY_COUNT_MAX)
DISK_RADIUS_M = random.uniform(INFLORESCENCE_DIAMETER_MIN_M, INFLORESCENCE_DIAMETER_MAX_M) / 2.0
RAY_LEN_M = DISK_RADIUS_M * 1.5  # rays are ~1.5x disk radius for composites
CAULINE_LEAF_LEN_M = ROSETTE_LEAF_MAX_LEN_M * 0.4

# === Material ids (carried as parameters; renderer applies via sidecar lookup) ===
ROSETTE_MAT = "{{ species.parameters.rosette.material_id }}"
