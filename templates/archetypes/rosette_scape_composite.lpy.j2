# === Axiom and derivation ===
Axiom: Plant(0, False, False)
derivation length: {{ species.phenology.abscission_doy + 30 }}

# === Productions ===
production:

# Plant: per-day clock. Fires phenology events when their DOY threshold
# is crossed. Uses _fired flags so the dispatch is idempotent regardless
# of EMERGENCE_OFFSET sign or T_RENDER alignment.
Plant(t_doy, rosette_fired, scape_fired) :
    effective_t = t_doy + TIME_OFFSET_DOY
    if (not rosette_fired) and effective_t >= EFFECTIVE_LEAF_FLUSH:
        produce Rosette(ROSETTE_LEAVES, t_doy) Plant(t_doy + 1, True, scape_fired)
    elif (not scape_fired) and effective_t >= EFFECTIVE_INFLO_EMERGE:
        produce ScapeBundle(SCAPE_COUNT, t_doy) Plant(t_doy + 1, rosette_fired, True)
    else:
        produce Plant(t_doy + 1, rosette_fired, scape_fired)

# Rosette ladder: emit N leaves spiraled at golden angle, then disappear.
Rosette(n_remaining, t_birth) :
    if n_remaining > 0:
        rotation = ROSETTE_PHYLLOTAXY_DEG * (ROSETTE_LEAVES - n_remaining)
        produce [/(rotation) RosetteLeaf(t_birth, ROSETTE_LEAF_MAX_LEN_M, ROSETTE_MAT)] Rosette(n_remaining - 1, t_birth)
    else:
        produce *

# ScapeBundle: distribute N scapes around the central point, then disappear.
ScapeBundle(n_remaining, t_birth) :
    if n_remaining > 0:
        angle = (n_remaining - 1) * 30
        produce [/(angle) Scape(0, t_birth, False)] ScapeBundle(n_remaining - 1, t_birth)
    else:
        produce *

# Scape: queryable per-instance dispatcher.
# Multi-iteration grower; uses `done` flag for persistent-marker pattern.
# Each iteration emits one ScapeSegment with the current DOY as t_birth,
# until SCAPE_SEGMENT_COUNT is reached. At completion, emits cauline leaf
# + final segment + bud, then marks itself done so it persists in the
# lstring as a queryable Scape marker.
Scape(seg_count, t_birth_scape, done) :
    if done:
        produce Scape(seg_count, t_birth_scape, True)
    current_t = getIterationNb()
    if seg_count < SCAPE_SEGMENT_COUNT:
        produce ScapeSegment(current_t, SCAPE_SEGMENT_LEN_M, SCAPE_MAT) Scape(seg_count + 1, t_birth_scape, False)
    elif seg_count == SCAPE_SEGMENT_COUNT:
        produce CaulineLeaf(current_t, CAULINE_LEAF_LEN_M, ROSETTE_MAT) ScapeSegment(current_t, SCAPE_SEGMENT_LEN_M, SCAPE_MAT) InfloBud(current_t) Scape(seg_count + 1, t_birth_scape, True)
    else:
        produce Scape(seg_count, t_birth_scape, True)

# InfloBud: waits for inflorescence-peak DOY then transforms into InfloHead.
# Not queryable in its own right (it's a transient state); InfloHead is.
InfloBud(t_birth_bud) :
    current_t = getIterationNb()
    effective_t = current_t + TIME_OFFSET_DOY
    if effective_t >= EFFECTIVE_INFLO_PEAK:
        produce InfloHead(current_t, False)
    else:
        produce InfloBud(t_birth_bud)

# InfloHead: queryable per-instance dispatcher (Andropogon-style one-shot).
# Persistent marker injected via the `queryable_one_shot` macro.
{{ queryable_one_shot("InfloHead", "t_birth", "t_birth", "DiskFloret(t_birth, DISK_RADIUS_M, DISK_MAT) RayRing(RAY_COUNT, t_birth)") }}

# RayRing: emit N ray florets equally spaced around the head, then disappear.
RayRing(n_remaining, t_birth) :
    if n_remaining > 0:
        ray_angle = 360.0 * (RAY_COUNT - n_remaining) / RAY_COUNT
        produce [/(ray_angle) RayFloret(t_birth, RAY_LEN_M, RAY_MAT)] RayRing(n_remaining - 1, t_birth)
    else:
        produce *

# === Interpretation: AGE-AWARE GEOMETRY ===
# Single-line --> rules only (Spike 1 finding).
# Multi-line bodies use ":" + "produce" form.

interpretation:

RosetteLeaf(t_birth, max_len_m, mat_id) :
    age = T_RENDER + TIME_OFFSET_DOY - (t_birth + EMERGENCE_OFFSET)
    if age < 0:
        produce *
    size_m = sigmoid_grow(age, LEAF_GROWTH_DAYS, max_len_m)
    produce [&(80) ;(2) ~l(size_m)]

ScapeSegment(t_birth, seg_len_m, mat_id) :
    age = T_RENDER + TIME_OFFSET_DOY - (t_birth + EMERGENCE_OFFSET)
    if age < 0:
        produce *
    grown_m = sigmoid_grow(age, SEGMENT_GROWTH_DAYS, seg_len_m)
    produce ;(4) F(grown_m)

CaulineLeaf(t_birth, len_m, mat_id) :
    age = T_RENDER + TIME_OFFSET_DOY - (t_birth + EMERGENCE_OFFSET)
    if age < 0:
        produce *
    size_m = sigmoid_grow(age, LEAF_GROWTH_DAYS, len_m)
    produce [&(60) ;(2) ~l(size_m)]

InfloBud(t_birth) :
    age = T_RENDER + TIME_OFFSET_DOY - (t_birth + EMERGENCE_OFFSET)
    if age < 0:
        produce *
    size_m = sigmoid_grow(age, INFLO_BUD_GROWTH_DAYS, INFLORESCENCE_DIAMETER_MIN_M / 4.0)
    produce ;(2) @O(size_m)

DiskFloret(t_birth, radius_m, mat_id) :
    age = T_RENDER + TIME_OFFSET_DOY - (t_birth + EMERGENCE_OFFSET)
    if age < 0:
        produce *
    r_m = sigmoid_grow(age, DISK_GROWTH_DAYS, radius_m)
    produce ;(6) @O(r_m)

RayFloret(t_birth, len_m, mat_id) :
    age = T_RENDER + TIME_OFFSET_DOY - (t_birth + EMERGENCE_OFFSET)
    if age < 0:
        produce *
    size_m = sigmoid_grow(age, RAY_GROWTH_DAYS, len_m)
    produce [&(70) ;(5) ~l(size_m)]

