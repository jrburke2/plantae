{% from "macros/queryable.lpy.j2" import one_shot as queryable_one_shot %}
import math
from growth_functions import sigmoid_grow, alpha_at, draw_growth_days
from plant_sim.runtime.pcg import seeded_rng

# === Externs (overridden from Python via lsys.context()) ===
extern(T_RENDER = {{ "%.1f" % render.t_render_default }})
extern(SPECIMEN_SEED = {{ render.seed }})
extern(TIME_OFFSET_DOY = {{ "%.1f" % render.time_offset_doy }})
extern(EMERGENCE_OFFSET = {{ "%.1f" % render.emergence_offset_days }})
extern(POSITION_X_M = {{ "%.4f" % render.position_x_m }})
extern(POSITION_Y_M = {{ "%.4f" % render.position_y_m }})
extern(POSITION_Z_M = {{ "%.4f" % render.position_z_m }})

# === Per-specimen RNG seeded once at file top ===
# PCG-XSL-RR-128/64 -- portable across Python (here) and JS (V2.1+).
rng = seeded_rng(SPECIMEN_SEED)

# === Phenology (median DOY values from species YAML) ===
LEAF_FLUSH_DOY = {{ species.phenology.leaf_flush_doy }}
PEAK_DOY = {{ species.phenology.peak_doy }}
SENESCENCE_ONSET_DOY = {{ species.phenology.senescence_onset_doy }}
ABSCISSION_DOY = {{ species.phenology.abscission_doy }}
INFLORESCENCE_EMERGE_DOY = {{ species.phenology.inflorescence_emerge_doy or species.phenology.peak_doy }}
INFLORESCENCE_PEAK_DOY = {{ species.phenology.inflorescence_peak_doy or species.phenology.peak_doy }}
INFLORESCENCE_SENESCENCE_DOY = {{ species.phenology.inflorescence_senescence_doy or species.phenology.senescence_onset_doy }}

# === Clump architecture ===
TILLER_COUNT = {{ species.parameters.clump.tiller_count }}
TILLER_HEIGHT_MIN_M = {{ "%.6f" % m.clump.tiller_height_min }}
TILLER_HEIGHT_MAX_M = {{ "%.6f" % m.clump.tiller_height_max }}
FRACTION_FLOWERING = {{ species.parameters.clump.fraction_flowering }}
VEGETATIVE_HEIGHT_FRAC = {{ species.parameters.clump.vegetative_height_fraction }}

# === Tiller architecture ===
LEAF_COUNT_MIN = {{ species.parameters.tiller.leaf_count_range[0] }}
LEAF_COUNT_MAX = {{ species.parameters.tiller.leaf_count_range[1] }}
PHYLLOTAXY_DEG = {{ species.parameters.tiller.phyllotaxy_deg }}

# === Panicle (inflorescence) architecture ===
RACEME_COUNT_MIN = {{ species.parameters.panicle.raceme_count_range[0] }}
RACEME_COUNT_MAX = {{ species.parameters.panicle.raceme_count_range[1] }}
RACEME_LENGTH_M = {{ "%.6f" % m.panicle.raceme_length }}
RACEME_DIVERGENCE_DEG = {{ species.parameters.panicle.raceme_divergence_deg }}

# === Material ids (carried as parameters; renderer applies via sidecar lookup) ===
LEAF_MAT = "{{ species.parameters.tiller.leaf_material_id }}"
CULM_MAT = "{{ species.parameters.tiller.culm_material_id }}"
PANICLE_MAT = "{{ species.parameters.panicle.material_id }}"
CROWN_MAT = "crown_dark"

# === Growth windows (Phase 0 hardcoded; see templates/archetypes/README.md for extension plan) ===
LEAF_GROWTH_DAYS = 21.0
CROWN_GROWTH_DAYS = 5.0
RACEME_GROWTH_DAYS = 7.0

# === Effective phenology (median + per-specimen jitter) ===
EFFECTIVE_LEAF_FLUSH = LEAF_FLUSH_DOY + EMERGENCE_OFFSET
EFFECTIVE_INFLO_EMERGE = INFLORESCENCE_EMERGE_DOY + EMERGENCE_OFFSET

# Crown radius for the basal meristem (a small lump at the clump base).
CROWN_RADIUS_M = max(0.01, TILLER_HEIGHT_MAX_M * 0.012)

# === Module declarations ===
# Multi-character names MUST be declared (Spike 1 finding).
# Queryable per-instance modules carry an `expanded` flag for the
# persistent-marker pattern (Spike 2 finding); the codegen emits the
# `if expanded: produce self(...,True)` guard for those rules.
module Clump(t_doy, fired)
module TillerBundle(n_remaining, n_total, t_birth, frac_flowering)
module Tiller(idx, t_birth, max_height_m, n_leaves, is_flowering, expanded)
module Crown(t_birth, radius_m, mat_id)
module LeafLadder(n_remaining, n_total, t_birth, tiller_height_m)
module GrassLeaf(t_birth, position_frac, blade_length_m, mat_id)
module CulmSegment(t_birth, length_m, mat_id)
module CulmStem(t_birth, max_height_m)
module Panicle(t_birth, n_racemes, expanded)
module RacemeBundle(n_remaining, n_total, t_birth)
module Raceme(t_birth, length_m, mat_id)

# === Axiom and derivation ===
Axiom: Clump(0, False)
derivation length: {{ species.phenology.abscission_doy + 30 }}

# === Productions ===
production:

# Clump dispatcher: fires the TillerBundle once at LEAF_FLUSH_DOY.
Clump(t_doy, fired) :
    effective_t = t_doy + TIME_OFFSET_DOY
    if (not fired) and effective_t >= EFFECTIVE_LEAF_FLUSH:
        produce TillerBundle(TILLER_COUNT, TILLER_COUNT, t_doy, FRACTION_FLOWERING) Clump(t_doy + 1, True)
    else:
        produce Clump(t_doy + 1, fired)

# TillerBundle: recursive emitter; each Tiller draws its stochastic params
# at production firing (rng.uniform / rng.randint baked into Tiller's
# parameters per Andropogon Q2 finding).
TillerBundle(n_remaining, n_total, t_birth, frac_flowering) :
    if n_remaining > 0:
        height_m = rng.uniform(TILLER_HEIGHT_MIN_M, TILLER_HEIGHT_MAX_M)
        n_leaves = rng.randint(LEAF_COUNT_MIN, LEAF_COUNT_MAX)
        is_flowering = rng.random() < frac_flowering
        idx = n_total - n_remaining
        base_angle = idx * (360.0 / n_total)
        jitter = rng.uniform(-10, 10)
        elevation = rng.uniform(0, 8)
        produce [/(base_angle + jitter) +(elevation) Tiller(idx, t_birth, height_m, n_leaves, is_flowering, False)] TillerBundle(n_remaining - 1, n_total, t_birth, frac_flowering)
    else:
        produce *

# Tiller: queryable one-shot dispatcher. Variant dispatch via is_flowering.
# Persistent-marker injected via the queryable_one_shot macro inline (the
# variant dispatch makes a generic macro call awkward; explicit if/else
# matches the Andropogon spike's pattern exactly).
Tiller(idx, t_birth, max_height_m, n_leaves, is_flowering, expanded) :
    if expanded:
        produce Tiller(idx, t_birth, max_height_m, n_leaves, is_flowering, True)
    effective_height_m = max_height_m if is_flowering else max_height_m * VEGETATIVE_HEIGHT_FRAC
    if is_flowering:
        produce Tiller(idx, t_birth, max_height_m, n_leaves, is_flowering, True) Crown(t_birth, CROWN_RADIUS_M, CROWN_MAT) LeafLadder(n_leaves, n_leaves, t_birth, effective_height_m) CulmStem(t_birth, effective_height_m)
    else:
        produce Tiller(idx, t_birth, max_height_m, n_leaves, is_flowering, True) Crown(t_birth, CROWN_RADIUS_M, CROWN_MAT) LeafLadder(n_leaves, n_leaves, t_birth, effective_height_m)

# LeafLadder: distichous (or whatever phyllotaxy) leaf placement up the tiller.
# Each iteration emits a CulmSegment (so the F() shape carries a mat_id) plus
# a leaf at the appropriate rotation.
LeafLadder(n_remaining, n_total, t_birth, tiller_height_m) :
    if n_remaining > 0:
        current_t = getIterationNb()
        position_frac = (n_total - n_remaining + 1) / (n_total + 1.0)
        rotation = PHYLLOTAXY_DEG * (n_total - n_remaining)
        # Blades longest mid-tiller, shorter at apex (typical grass profile).
        blade_length_m = tiller_height_m * 0.25 * (1.0 - abs(position_frac - 0.4) * 0.8)
        seg_len_m = tiller_height_m * (1.0 / (n_total + 1))
        produce CulmSegment(current_t, seg_len_m, CULM_MAT) [/(rotation) GrassLeaf(t_birth, position_frac, blade_length_m, LEAF_MAT)] LeafLadder(n_remaining - 1, n_total, t_birth, tiller_height_m)
    else:
        produce *

# CulmStem: continues upward; emits Panicle once INFLO_EMERGE DOY is reached.
# The terminal upper-culm segment is wrapped in CulmSegment so it picks up a
# material_id like the lower segments.
CulmStem(t_birth, max_height_m) :
    current_t = getIterationNb()
    if current_t >= EFFECTIVE_INFLO_EMERGE:
        n_racemes = rng.randint(RACEME_COUNT_MIN, RACEME_COUNT_MAX)
        produce CulmSegment(current_t, max_height_m * 0.15, CULM_MAT) Panicle(current_t, n_racemes, False)
    else:
        produce CulmStem(t_birth, max_height_m)

# Panicle: queryable one-shot dispatcher (same pattern as Tiller).
Panicle(t_birth, n_racemes, expanded) :
    if expanded:
        produce Panicle(t_birth, n_racemes, True)
    produce Panicle(t_birth, n_racemes, True) RacemeBundle(n_racemes, n_racemes, t_birth)

# RacemeBundle: emit N racemes radiating from a single point.
RacemeBundle(n_remaining, n_total, t_birth) :
    if n_remaining > 0:
        angle = (n_total - n_remaining) * (360.0 / n_total)
        produce [/(angle) +(RACEME_DIVERGENCE_DEG) Raceme(t_birth, RACEME_LENGTH_M, PANICLE_MAT)] RacemeBundle(n_remaining - 1, n_total, t_birth)
    else:
        produce *

# === Interpretation: AGE-AWARE GEOMETRY ===
# Single-line --> rules only (Spike 1 finding).

interpretation:

Crown(t_birth, radius_m, mat_id) :
    age = T_RENDER + TIME_OFFSET_DOY - (t_birth + EMERGENCE_OFFSET)
    if age < 0:
        produce *
    r_m = sigmoid_grow(age, CROWN_GROWTH_DAYS, radius_m)
    produce ;(6) @O(r_m)

GrassLeaf(t_birth, position_frac, blade_length_m, mat_id) :
    age = T_RENDER + TIME_OFFSET_DOY - (t_birth + EMERGENCE_OFFSET)
    if age < 0:
        produce *
    size_m = sigmoid_grow(age, LEAF_GROWTH_DAYS, blade_length_m)
    produce [&(70) ;(2) ~l(size_m)]

CulmSegment(t_birth, length_m, mat_id) :
    age = T_RENDER + TIME_OFFSET_DOY - (t_birth + EMERGENCE_OFFSET)
    if age < 0:
        produce *
    grown_m = sigmoid_grow(age, 1.0, length_m)
    produce ;(2) F(grown_m)

Raceme(t_birth, length_m, mat_id) :
    age = T_RENDER + TIME_OFFSET_DOY - (t_birth + EMERGENCE_OFFSET)
    if age < 0:
        produce *
    grown_m = sigmoid_grow(age, RACEME_GROWTH_DAYS, length_m)
    produce ;(4) _(0.005) F(grown_m)

# === Hide bookkeeping modules (no visible geometry) ===
Clump(t, f) --> ;(0) f(0)
TillerBundle(n, m, t, f) --> ;(0) f(0)
Tiller(i, t, h, n, f, e) --> ;(0) f(0)
LeafLadder(n, m, t, h) --> ;(0) f(0)
CulmStem(t, h) --> ;(0) f(0)
Panicle(t, n, e) --> ;(0) f(0)
RacemeBundle(n, m, t) --> ;(0) f(0)

endlsystem
